APP_NAME=Apprumo
APP_ENV=production
APP_DEBUG=false
APP_URL=https://jssistemasinteligentes.com/Apprumo
APP_TIMEZONE=America/Sao_Paulo
APP_FORCE_HTTPS=true
APP_TRUST_PROXY=true

# XAMPP (pasta htdocs/Apprumo): APP_ENV=local APP_URL=http://localhost/Apprumo APP_FORCE_HTTPS=false SESSION_COOKIE_SECURE=false
# Hostinger (subpasta /Apprumo): mantenha APP_URL com o caminho completo acima.

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=apprumo
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

SUPPORT_WHATSAPP=5511999999999
DEFAULT_BUTTON_COLOR=#ddb76a
ADMIN_EMAILS=admin@example.com

# ── E-mail SMTP (opcional — sem SMTP usa mail() do PHP) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu@gmail.com
# SMTP_PASS=senha-de-app
# MAIL_FROM=noreply@apprumo.com.br

# ── SMS API (opcional — Twilio ou compatível) ──
# SMS_API_URL=https://api.twilio.com/2010-04-01/Accounts/ACXXX/Messages.json
# SMS_API_KEY=sua_api_key
# SMS_FROM_NUMBER=+5511999999999

# ── WhatsApp Business API (Meta Cloud API) ──
# O vendedor configura seu próprio token e Phone ID em Configurações > WhatsApp Business.
# Para criar uma conta WhatsApp Business API:
#   1. Acesse https://developers.facebook.com → criar app tipo "Business"
#   2. Adicione o produto "WhatsApp" ao app
#   3. Configure um número de telefone de teste ou produção
#   4. Gere um token de acesso permanente
#   5. Copie o "Phone Number ID" e o token para as configurações do Apprumo
#
# APIs de WhatsApp recomendadas (mais acessíveis):
#   - Meta Cloud API (GRATUITA - 1000 msgs/mês grátis): https://developers.facebook.com/docs/whatsapp/cloud-api
#   - Z-API (a partir de R$49,90/mês): https://www.z-api.io
#   - Evolution API (open-source, self-hosted): https://github.com/EvolutionAPI/evolution-api

UPLOAD_MAX_BYTES=5242880
SESSION_COOKIE_SECURE=true
SESSION_SAME_SITE=Lax
SESSION_IDLE_TIMEOUT=7200

# Quantos dias antes do vencimento mostrar aviso no painel do vendor
PLAN_EXPIRY_WARNING_DAYS=7

# Janela usada no admin para o filtro "A vencer"
ADMIN_PLAN_DUE_SOON_DAYS=10

# ── IA Assistente (Groq — gratuita) ──
# Crie uma conta em https://console.groq.com e gere uma API key.
# A IA assistente aparecerá como um chatbot flutuante no painel do vendedor.
# Sem esta chave, o chatbot funciona com respostas offline básicas.
# GROQ_API_KEY=gsk_xxxxxxxxxxxx
